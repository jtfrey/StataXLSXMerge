#!/usr/bin/env python
#
# Self-contained set of classes and driver code that reads
# a set of <N> .xlsx files produced by the Stata `putexcel`
# command and merges then into a single .xslx document.
#
# * The sharedStrings arrays from the <N> source files
#   are consolidated into a single set of unique values
#   with mappings for each source's string id space to
#   the consolidated space.
# * The font, fill, border, and numFmt records from each
#   of the <N> source's styles are consolidated into a
#   single set of unique records with mappings for each
#   source's index space to the consolidated space.
# * The named styles from the <N> sources are
#   consolidated into a single set of unique records
#   with mappings for each source's index space to the
#   consolidated space.
# * The full set of cell styles for each source is
#   retained, with the font, fill, border, numFmt, and
#   parent named style ids remapped to the final
#   consolidated spaces.
# * Worksheets can be read and the string and style
#   ids remapped to the final consolidated spaces.
# * The agglomeration of consolidated strings, styles,
#   and worksheets can be exported to a .xlsx file.
#

import xml.etree.ElementTree as ET
import argparse
import pathlib
import logging
import copy

logging.basicConfig(format='%(levelname)s: %(message)s', level=logging.ERROR)

#
# We'll use Python's built-in 'zipfile' module, but on older
# Python 3 releases the mkdir() method is not present -- so
# we'll subclass ZipFile and add that method to it.  Coming
# out of this section, all zip files should be handled using
# the ZipFileClass class (which may be that subclass or a
# reference to the zipfile.ZipFile class itself).
#
import zipfile
if hasattr(zipfile.ZipFile, 'mkdir'):
    if not callable(getattr(zipfile.ZipFile, 'mkdir')):
        raise RuntimeError('Current zipfile module defines ZipFile.mkdir but is NOT callable!')
    # We're okay with this version as-is:
    ZipFileClass = zipfile.ZipFile
else:
    class ZipFileClass(zipfile.ZipFile):
    
        def mkdir(self, zinfo_or_directory_name, mode=511):
            """Creates a directory inside the zip archive."""
            if isinstance(zinfo_or_directory_name, zipfile.ZipInfo):
                directory_name = zinfo_or_directory_name.filename
            elif isinstance(zinfo_or_directory_name, str):
                directory_name = zinfo_or_directory_name
            else:
                raise TypeError("Expected type str or ZipInfo")
            if not directory_name.endswith('/'):
                directory_name += '/'
            zinfo = zipfile.ZipInfo(directory_name)
            zinfo.compress_size = 0
            zinfo.CRC = 0
            zinfo.external_attr = ((0o40000 | mode) & 0xFFFF) << 16
            zinfo.file_size = 0
            zinfo.external_attr |= 0x10
            self.writestr(zinfo, '')

#
# A subclass of the XML element that adds a source id attribute
# for the sake of identifying while file the XML object originated
# in:
#
class XLSXMLWrapper(ET.Element):

    def getSrcId(self):
        if hasattr(self, '__XLSObject_src_id'): return getattr(self, '__XLSObject_src_id')
        return None
    def setSrcId(self, src_id):
        setattr(self, '__XLSObject_src_id', src_id)




#
# Generic transformation of an XML element into a string representation
# e.g. for the sake of classes' __str__() methods.
#
# Recursive format that looks like:
#
#     <tag>             XML element tag
#     <attr#>           XML element attribute name
#     <val#>            XML element attribute value
#     <e{#}>            XML element representation
#
#     <e{#}> := <tag>:[<attr1>=<val1>,<attr2>=<val2>,…]{<e1>,<e2>,…}
#
def xmlElementToString(e):
    out_str = e.tag + ':['
    d = ''
    attrkeys = [k for k in e.attrib.keys()]
    attrkeys.sort()
    for attr in attrkeys:
        out_str += f'{d}{attr}="{e.attrib[attr]}"'
        d = ','
    out_str += ']{'
    d = ''
    for c in e:
        out_str += d + xmlElementToString(c)
        d = ','
    out_str += '}'
    return out_str

#
# Recursive XML element comparator
#
# Returns true if e1 and e2 have the same element tag (sans namespace);
# the same text body (and trailing text); the same set of attributes
# and values to those attributes; and the same set of child elements
# (not necessarily in the same order).
#
def xmlElementsEqual(e1, e2):
    ename1 = e1.tag.split('}')[-1]
    ename2 = e2.tag.split('}')[-1]
    if ename1 != ename2 or e1.text != e2.text or e1.tail != e2.tail: return False
    if e1.attrib != e2.attrib or len(e1) != len(e2): return False
    c2set = set([c for c in e2])
    for c1 in e1:
        found = False
        for c2 in c2set:
            if xmlElementsEqual(c1, c2):
                c2set.remove(c2)
                found = True
                break
        if not found: return False
    if len(c2set) > 0: return False
    return True

#
# Recursive clone of an XML element
#
# Creates a deep copy of the element e with the same tag (sans namespace),
# attributes, and child elements.
#
def xmlCopyElement(e):
    ename = e.tag.split('}')[-1]
    elem = XLSXMLWrapper(ename)
    for k,v in e.attrib.items():
        k = k.split('}')[-1]
        elem.attrib[k] = v
    if e.text is not None: elem.text = str(e.text)
    if e.tail is not None: elem.tail = str(e.tail)
    for c in e:
        elem.append(xmlCopyElement(c))
    return elem

#
# Object index abstract base class
#
# As duplicate metadata are removed, the association between the source
# .xlsx file's values and the newly-consolidated values must be maintained.
# Concrete subclasses of XLSObjectIndexMap represent those associations.
#
class XLSObjectIndexMap(object):

    # Subclasses must override this with the collection type
    # that will hold the associations (e.g. list, dict)
    _use_this_type = None
    
    def __init__(self):
        self._index = self.__class__._use_this_type()
    
    def __len__(self): return len(self._index)
    def __getitem__(self, idx): return self.getMappedIndex(idx)
    def __setitem__(self, idx, value): return self.setMappedIndex(idx, value)
    def __iter__(self): return iter(self._index)
    def __contains__(self, idx): return idx in self._index
    
    # Subclasses must override this with a method to retrieve
    # the consolidated index associated with source index, in_index.
    def getMappedIndex(self, in_index):
        pass
        
    # Subclasses must override this with a method to set
    # the consolidated index to_index that is associated with source
    # index, in_index.
    def setMappedIndex(self, in_index, to_index):
        pass

#
# List-based object index
#
# Source indices are assumed to be zero-based and sequential.
#
class XLSObjectIndexMapList(XLSObjectIndexMap):

    _use_this_type = list
    
    def getMappedIndex(self, in_index):
        if in_index >= 0 and in_index < len(self._index):
            return self._index[in_index]
        raise IndexError(f'Index {in_index} out of range [0,{len(self._index)}) in XLSObjectIndexMapList')
        
    def setMappedIndex(self, in_index, to_index):
        if in_index >= 0 and in_index < len(self._index):
            self._index[in_index] = to_index            
        else:
            while in_index > len(self._index):
                self._index.append(-1)
            self._index.append(to_index)

#
# Dictionary-based object index
#
# Source indices can have any value and appear in any order.
#
class XLSObjectIndexMapDict(XLSObjectIndexMap):

    _use_this_type = dict
    
    def __init__(self, shouldIgnoreMissing=False):
        self._index = dict()
        self._shouldIgnoreMissing = shouldIgnoreMissing
    
    def getMappedIndex(self, in_index):
        if in_index in self._index:
            return self._index[in_index]
        if self._shouldIgnoreMissing:
            return in_index
        raise IndexError(f'Index {in_index} not present in XLSObjectIndexMapDict')
        
    def setMappedIndex(self, in_index, to_index):
        self._index[in_index] = to_index
        

#
# Each Excel metadata object has a class associated with
# it.  That class has a shared and per-source registry of
# objects.  The shared registry only receives unique
# objects; the per-source registry associates the original
# index with the index in the shared registry:
#
#     _sharedRegistry = [XLSFont(), XLSFont(), …]
#     _perSourceRegistry = { 'file1': [ 0, 1, … ],
#                            'file2': [ 15, 16, … ] }
#
# Where the per-source arrays reference the index in the
# shared registry.
#
# Each class _can_ override the shared or per-source registry
# to use a dictionary rather than an array if objects are NOT
# indexed sequentially from zero.
#
class XLSObject(object):

    # The class should define its own element tag name...
    _valid_element_tag = None

    @classmethod
    def getSharedRegistryInstance(cls):
        return list()
    @classmethod
    def getSharedRegistry(cls):
        if getattr(cls, '_sharedRegistry', None) is None:
            cls._sharedRegistry = cls.getSharedRegistryInstance()
        return cls._sharedRegistry
    @classmethod
    def nextSharedRegistryIndex(cls):
        return len(cls.getSharedRegistry())
        
    @classmethod
    def baseExportXMLElement(cls):
        raise NotImplementedError('Subclasses MUST override the baseExportXMLElement() method')
        
    @classmethod
    def wrapXMLElementForExport(cls, xml_element, shared_index):
        return xml_element
        
    @classmethod
    def sharedRegistryToXML(cls):
        root_element = cls.baseExportXMLElement()
        shared_registry = cls.getSharedRegistry()
        if isinstance(shared_registry, dict):
            for k,v in shared_registry.items():
                root_element.append(cls.wrapXMLElementForExport(v.xmlElementForExport(), k))
        else:
            i = 0
            for v in shared_registry:
                root_element.append(cls.wrapXMLElementForExport(v.xmlElementForExport(), i))
                i += 1
        return root_element
    
    @classmethod
    def incrementTotalCount(cls):
        if getattr(cls, '_totalCount', None) is None:
            cls._totalCount = 1
        else:
            cls._totalCount += 1
    @classmethod
    def getTotalCount(cls):
        return getattr(cls, '_totalCount', 0)

    @classmethod
    def getPerSourceRegistryInstance(cls):
        return XLSObjectIndexMapList()
    @classmethod
    def getPerSourceRegistry(cls, src_id):
        if getattr(cls, '_perSourceRegistry', None) is None:
            cls._perSourceRegistry = {}
        if src_id not in cls._perSourceRegistry:
            cls._perSourceRegistry[src_id] = cls.getPerSourceRegistryInstance()
        return cls._perSourceRegistry[src_id]
    @classmethod
    def proposedPerSourceIndexForXMLElement(cls, src_id, xml_element):
        return len(cls.getPerSourceRegistry(src_id))
    
    @classmethod
    def sharedIndexForPerSourceIndex(cls, src_id, per_source_index):
        psr = cls.getPerSourceRegistry(src_id)
        return psr[per_source_index]

    @classmethod
    def registerXMLElement(cls, src_id, xml_element):
        # Attach a source id to the element:
        new_element = xmlCopyElement(xml_element)
        new_element.setSrcId(src_id)
        
        # Is the incoming object already present in the global
        # registry?
        shared_registry = cls.getSharedRegistry()
        if isinstance(shared_registry, dict):
            is_present = new_element in shared_registry.values()
        else:
            is_present = new_element in shared_registry
        per_source_index = cls.proposedPerSourceIndexForXMLElement(src_id, new_element)
        if not is_present:
            new_object = cls(src_id,
                            cls.nextSharedRegistryIndex(),
                            per_source_index,
                            new_element)
            shared_index, per_source_index = new_object.indices()
            if isinstance(shared_registry, dict):
                shared_registry[shared_index] = new_object
            else:
                shared_registry.append(new_object)
        else:
            if isinstance(shared_registry, dict):
                shared_index = None
                for k,v in shared_registry.items():
                    if v == new_element:
                        shared_index = k
                        break;
                if shared_index is None:
                    raise RuntimeError(f'Expected value for a {new_element.tag} not found in shared registry')
            else:
                shared_index = shared_registry.index(new_element)
        cls.incrementTotalCount()
        cls.getPerSourceRegistry(src_id)[per_source_index] = shared_index
        
    def __init__(self, src_id, shared_idx, per_source_idx, xml_element):
        self._src_id = src_id
        self._xml_element = xml_element
        self._shared_index = shared_idx
        self._per_source_index = per_source_idx
    
    def __repr__(self):
        return xmlElementToString(self._xml_element)
    
    def __hash__(self):
        return hash(xmlElementToString(self._xml_element))

    def __eq__(self, other):
        if isinstance(other, XLSObject):
            return xmlElementsEqual(self._xml_element, other._xml_element)
        return xmlElementsEqual(self._xml_element, other)
    
    def srcId(self): return self._src_id
    def xmlElement(self): return self._xml_element
    def xmlElementForExport(self): return self.xmlElement()
    
    def indices(self): return (self._shared_index, self._per_source_index)
    def sharedIndex(self): return self._shared_index
    def perSourceIndex(self): return self._per_source_index
    
    def getAttribute(self, name):
        if name in self._xml_element.attrib:
            return self._xml_element.attrib[name]
        raise KeyError(f'No such attribute `{name}` on {self.__class__._valid_element_tag} element')
    def setAttribute(self, name, value):
        self._xml_element.attrib[name] = value


class XLSString(XLSObject):

    _valid_element_tag = 't'
        
    @classmethod
    def baseExportXMLElement(cls):
        e = ET.Element('sst')
        e.attrib['xmlns'] = 'http://schemas.openxmlformats.org/spreadsheetml/2006/main'
        e.attrib['count'] = str(cls.getTotalCount())
        e.attrib['uniqueCount'] = str(len(cls.getSharedRegistry()))
        return e
        
    @classmethod
    def wrapXMLElementForExport(cls, xml_element, shared_index):
        e = ET.Element('si')
        e.append(xml_element)
        return e
    
    @classmethod
    def getFullCount(cls):
        return cls._fullCount if hasattr(cls, '_fullCount') else 0
    @classmethod
    def addToFullCount(cls,  dcount):
        if not hasattr(cls, '_fullCount'):
            cls._fullCount = dcount
        else:
            cls._fullCount += dcount
    
    def __repr__(self): return f'"{self.string()}"'
    
    def __hash__(self): return hash(self.string())

    def __eq__(self, other):
        if isinstance(other, XLSString):
            return self.string() == other.string()
        if isinstance(other, ET.Element):
            return self.string() == other.text
        return False
    
    def string(self): return self._xml_element.text
    
class XLSFont(XLSObject):

    _valid_element_tag = 'font'
        
    @classmethod
    def baseExportXMLElement(cls):
        e = ET.Element('fonts')
        e.attrib['count'] = str(len(cls.getSharedRegistry()))
        return e
    
    def xmlElementForExport(self):
        e = self.xmlElement()
        color_element = e.find('./{*}color[@indexed]')
        if color_element is not None:
            e = xmlCopyElement(e)
            e.attrib['indexed'] = str(XLSIndexedColor.sharedIndexForPerSourceIndex(self.srcId(), int(e.attrib['indexed'])))
        return e
    
